---
interface Props {
  slug: string;
  title: string;
  date: Date;
}

const { slug, title, date } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
});
---

<article class="py-2.5 border-b border-(--color-border) last:border-b-0">
  <a href={`/posts/${slug}`} class="flex items-baseline justify-between gap-4 group no-underline">
    <span class="text-sm font-medium text-(--color-text) truncate group-hover:underline">
      {title}
    </span>
    <time
      datetime={date.toISOString()}
      class="text-xs text-(--color-text-muted) shrink-0"
    >
      {formatted}
    </time>
  </a>
</article>
