---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;

const nav = [
  { href: '/posts', label: 'Posts' },
  { href: '/topics', label: 'Topics' },
];
---

<header class="mb-10 md:mb-12">
  <nav class="flex items-baseline justify-between gap-4" aria-label="Main navigation">
    <a
      href="/"
      class="text-base font-semibold tracking-tight text-[var(--color-text)] no-underline hover:underline"
    >
      {SITE_TITLE}
    </a>
    <ul class="flex items-baseline gap-6 text-sm text-[var(--color-text-muted)]">
      {nav.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'hover:text-[var(--color-text)]',
              currentPath === href || currentPath.startsWith(href + '/')
                ? 'text-[var(--color-text)] font-medium'
                : ''
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
