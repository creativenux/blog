---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getSortedPosts, groupPostsByYear } from '../../lib/posts';
import { SITE_TITLE } from '../../consts';

const posts = await getSortedPosts();
const groupedPosts = groupPostsByYear(posts);
---

<BaseLayout title="Posts" description={`All posts on ${SITE_TITLE}.`}>
  <article>
    <h1 class="text-2xl font-semibold tracking-tight text-(--color-text) mb-6">
      Posts
    </h1>
    <p class="text-(--color-text-muted) mb-8 max-w-2xl text-sm">
      A chronological list of everything I've written.
    </p>

    {
      groupedPosts.map((group) => (
        <div class="grid grid-cols-[4rem_1fr] gap-x-6 border-t border-(--color-border) py-2.5 first:border-t-0">
          <p class="text-sm text-(--color-text-muted) pt-2">{group.year}</p>
          <div class="divide-y-0">
            {group.posts.map((post) => (
              <PostCard
                slug={post.slug}
                title={post.data.title}
                date={post.data.date}
              />
            ))}
          </div>
        </div>
      ))
    }
    
  </article>
</BaseLayout>
