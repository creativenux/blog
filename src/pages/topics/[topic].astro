---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTopics, getPostsByTopicSlug } from '../../lib/posts';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const topics = await getAllTopics();
  return topics.map(({ name, slug }) => ({
    params: { topic: slug },
    props: { topicName: name },
  }));
}

const { topicName } = Astro.props;
const posts = await getPostsByTopicSlug(Astro.params.topic!);
---

<BaseLayout
  title={`${topicName} — Topics`}
  description={`Posts about “${topicName}” on ${SITE_TITLE}.`}
>
  <article>
    <nav class="mb-6 text-sm" aria-label="Breadcrumb">
      <a href="/topics" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:underline">
        ← Topics
      </a>
    </nav>

    <h1 class="text-2xl font-semibold tracking-tight text-[var(--color-text)] mb-6">
      {topicName}
    </h1>

    {posts.length > 0 ? (
      <div class="divide-y-0">
        {posts.map((post) => (
          <PostCard
            slug={post.slug}
            title={post.data.title}
            date={post.data.date}
          />
        ))}
      </div>
    ) : (
      <p class="text-[var(--color-text-muted)] text-sm">No posts with this topic.</p>
    )}
  </article>
</BaseLayout>
