---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<BaseLayout title="About" description={SITE_DESCRIPTION}>
  <article class="prose">
    <h1 class="text-2xl font-semibold tracking-tight mb-5">About</h1>

    <p>
      I'm Toheeb. I work on the web—building interfaces, thinking about design systems, and trying to keep things simple.
    </p>

    <p>
      I care about readability, performance, and sites that work well for everyone. This blog is a place to share what I'm learning and thinking about.
    </p>

    <h2 class="text-xl font-semibold mt-8 mb-2">Contact</h2>
    <p class="text-[var(--color-text-muted)]">
      You can reach me at{' '}
      <a href="mailto:hello@creativenux.com" class="hover:underline">
        hello@creativenux.com
      </a>
      , or find me on{' '}
      <a href="https://twitter.com/creativenux" target="_blank" rel="noopener noreferrer" class="hover:underline">
        Twitter
      </a>
      {' '}and{' '}
      <a href="https://github.com/creativenux" target="_blank" rel="noopener noreferrer" class="hover:underline">
        GitHub
      </a>.
    </p>
  </article>
</BaseLayout>
