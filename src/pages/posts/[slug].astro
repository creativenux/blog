---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getReadingTimeMinutes, slugifyTopic } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const readingMins = getReadingTimeMinutes(post.body);
const pubDate = post.data.date.toISOString();
const formatted = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const topics = post.data.topics ?? [];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description ?? post.data.title}
  ogType="article"
  publishedTime={pubDate}
>
  <article class="prose">
    {/* Breadcrumbs / Back link */}
    <nav class="mb-6 text-sm" aria-label="Breadcrumb">
      <a href="/posts" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:underline">
        ← Back to posts
      </a>
    </nav>

    <header class="mb-8">
      <h1 class="text-2xl font-semibold tracking-tight text-[var(--color-text)] mb-2">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-[var(--color-text-muted)]">
        <time datetime={pubDate}>{formatted}</time>
        <span>·</span>
        <span>{readingMins} min read</span>
        {topics.length > 0 && (
          <>
            <span>·</span>
            <span class="flex flex-wrap gap-1.5">
              {topics.map((t) => (
                <a href={`/topics/${slugifyTopic(t)}`} class="hover:underline">
                  {t}
                </a>
              ))}
            </span>
          </>
        )}
      </div>
    </header>

    <div class="post-content">
      <Content />
    </div>
  </article>
</BaseLayout>
