---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTopics } from '../../lib/posts';
import { SITE_TITLE } from '../../consts';

const topics = await getAllTopics();
---

<BaseLayout title="Topics" description={`All topics on ${SITE_TITLE}.`}>
  <article>
    <h1 class="text-2xl font-semibold tracking-tight text-[var(--color-text)] mb-6">
      Topics
    </h1>
    <p class="text-[var(--color-text-muted)] mb-8 max-w-[42rem] text-sm">
      Browse posts by topic.
    </p>

    {topics.length > 0 ? (
      <ul class="flex flex-wrap gap-2">
        {topics.map(({ name, slug, count }) => (
          <li>
            <a
              href={`/topics/${slug}`}
              class="inline-block rounded px-2.5 py-1 text-xs text-[var(--color-text-muted)] bg-[var(--color-bg-elevated)] border border-[var(--color-border)] hover:text-[var(--color-text)] hover:border-[var(--color-text-muted)] no-underline"
            >
              {name}
              <span class="ml-1 opacity-70">({count})</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-[var(--color-text-muted)] text-sm">No topics yet.</p>
    )}
  </article>
</BaseLayout>
